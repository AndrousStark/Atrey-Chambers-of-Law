# ============================================
# Atrey Chambers - Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# --- Authentication ---
# Multiple admin emails (comma-separated)
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# PBKDF2 password hash (generate with: node scripts/generate-password-hash.mjs "your-password")
ADMIN_PASSWORD_HASH=

# HMAC-SHA256 session signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=

# --- Email (Nodemailer / Gmail) ---
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# --- Vercel Blob Storage ---
BLOB_READ_WRITE_TOKEN=

# --- Google Calendar Integration ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# --- Site URL (for CSRF origin validation) ---
NEXT_PUBLIC_SITE_URL=https://www.atreychambers.com
